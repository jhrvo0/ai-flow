{
  "_registry": "model-registry.example.json",
  "_docs": "Consulte o arquivo model-registry.example.json para o catalogo completo de modelos, tiers e parametros recomendados.",

  "models": {
    "model_for_planning": "huihui-qwen3-4b-instruct-2507",
    "model_for_coding": "qwen2.5-coder-7b-instruct",
    "model_for_review": "qwen2.5-coder-7b-instruct",
    "model_for_summary": "llama-3.2-3b-instruct",
    "assignment": {
      "planner": {
        "model": "huihui-qwen3-4b-instruct-2507",
        "temperature": 0.3,
        "max_tokens": 2048,
        "top_p": 0.9,
        "fallback_model": "qwen2.5-coder-7b-instruct"
      },
      "coder": {
        "model": "qwen2.5-coder-7b-instruct",
        "temperature": 0.2,
        "max_tokens": 4096,
        "top_p": 0.9
      },
      "reviewer": {
        "model": "qwen2.5-coder-7b-instruct",
        "temperature": 0.1,
        "max_tokens": 4096,
        "top_p": 0.85
      },
      "tester": {
        "model": "llama-3.2-3b-instruct",
        "temperature": 0.2,
        "max_tokens": 2048,
        "top_p": 0.9,
        "fallback_model": "qwen2.5-coder-7b-instruct"
      },
      "docs": {
        "model": "llama-3.2-3b-instruct",
        "temperature": 0.4,
        "max_tokens": 1024,
        "top_p": 0.95
      },
      "summarizer": {
        "model": "llama-3.2-3b-instruct",
        "temperature": 0.3,
        "max_tokens": 1024,
        "top_p": 0.9,
        "fallback_model": "qwen2.5-coder-7b-instruct"
      }
    }
  },

  "api": {
    "default_provider": "lm_studio",
    "lm_studio_base_url": "http://127.0.0.1:1234/v1",
    "ollama_base_url": "http://127.0.0.1:11434/v1",
    "temperature_coding": 0.2,
    "temperature_review": 0.1,
    "temperature_planning": 0.3
  },

  "project": {
    "language": "typescript",
    "framework": "react",
    "runtime": "node",
    "package_manager": "npm"
  },

  "commands": {
    "test": ["npm test", "npx vitest run"],
    "lint": ["npm run lint", "npx eslint . --ext .ts,.tsx"],
    "typecheck": ["npx tsc --noEmit"],
    "build": ["npm run build"],
    "format": ["npx prettier --check ."]
  },

  "quality_gate": {
    "max_files_per_change": 5,
    "max_lines_per_file": 300,
    "max_function_lines": 50,
    "block_extensions": [".exe", ".dll", ".so", ".dylib", ".bin"],
    "sensitive_patterns": [
      "migrations/",
      ".env",
      ".env.local",
      ".env.production",
      "config/database.yml",
      "docker-compose.yml",
      "secrets/"
    ]
  },

  "artifacts": {
    "root": ".ai-flow/artifacts",
    "current_task": ".ai-flow/artifacts/current-task.json",
    "task_state": ".ai-flow/artifacts/task-state.json",
    "task_context": ".ai-flow/artifacts/context.md",
    "task_quality": ".ai-flow/artifacts/quality.md",
    "task_notes": ".ai-flow/artifacts/notes.md"
  },

  "reports": {
    "dashboard": ".ai-flow/dashboard.html",
    "context_map": ".ai-flow/reports/project-context.html",
    "quality_gate": ".ai-flow/reports/quality-gate.html",
    "diagnosis": ".ai-flow/reports/ai-flow-diagnosis.md",
    "manual_test_checklist": ".ai-flow/reports/manual-test-checklist.md"
  },

  "paths": {
    "quality_gate_output": ".ai-flow/reports/quality-gate.html",
    "reports_dir": ".ai-flow/reports/",
    "artifacts_dir": ".ai-flow/artifacts/",
    "agents_dir": ".ai-flow/agents/",
    "workflows_dir": ".ai-flow/workflows/"
  }
}
